<script>
/* â•â• NAV & SCROLL â•â• */
const nav = document.getElementById('navbar');
window.addEventListener('scroll', () => {
  if (window.scrollY > 50) nav.classList.add('scrolled');
  else nav.classList.remove('scrolled');
});

const ham = document.getElementById('hamburger');
const mobNav = document.getElementById('mobileNav');
const mobClose = document.getElementById('mobileClose');

ham.addEventListener('click', () => mobNav.classList.add('open'));
mobClose.addEventListener('click', () => mobNav.classList.remove('open'));
function closeMob() { mobNav.classList.remove('open'); }

/* â•â• REVEAL â•â• */
const revEls = document.querySelectorAll('.reveal');
const revObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revObs.unobserve(e.target); } });
}, { threshold: 0.1 });
revEls.forEach(el => revObs.observe(el));

/* â•â• GALERÄ° KAROSELÄ° â•â• */
const gcSlides = document.querySelectorAll('.gc-slide');
const gcStage = document.getElementById('gcStage');
const gcCurrentEl = document.getElementById('gcCurrent');
let gcIndex = 0;
let gcTimer = null;
const gcTotal = gcSlides.length;

function gcRender() {
  gcSlides.forEach((s, i) => s.classList.toggle('active', i === gcIndex));
  if (gcCurrentEl) gcCurrentEl.textContent = String(gcIndex + 1).padStart(2, '0');
}
function gcNext() { gcIndex = (gcIndex + 1) % gcTotal; gcRender(); gcResetAutoplay(); }
function gcPrev() { gcIndex = (gcIndex - 1 + gcTotal) % gcTotal; gcRender(); gcResetAutoplay(); }
function gcGoTo(i) { gcIndex = i; gcRender(); gcResetAutoplay(); }
function gcAutoplay() { gcTimer = setInterval(() => { gcIndex = (gcIndex + 1) % gcTotal; gcRender(); }, 5000); }
function gcResetAutoplay() { clearInterval(gcTimer); gcAutoplay(); }

if (gcStage && gcTotal > 0) {
  gcAutoplay();
  gcStage.addEventListener('mouseenter', () => clearInterval(gcTimer));
  gcStage.addEventListener('mouseleave', () => gcAutoplay());

  let gcTouchStartX = 0;
  gcStage.addEventListener('touchstart', e => { gcTouchStartX = e.touches[0].clientX; }, { passive: true });
  gcStage.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - gcTouchStartX;
    if (Math.abs(dx) > 50) { dx > 0 ? gcPrev() : gcNext(); }
  }, { passive: true });

  const gcVisibilityObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { e.isIntersecting ? gcAutoplay() : clearInterval(gcTimer); });
  }, { threshold: 0.2 });
  gcVisibilityObs.observe(gcStage);
}

/* â•â• REZERVASYON SÄ°STEMÄ° â•â• */
const PRICES = { "85": 85, "99": 99, "120": 120 };
const EXCHANGE_RATE = 53.00;
const WA_NUM = "905322622773";

function formatDate(dateStr) {
  if(!dateStr) return "";
  const parts = dateStr.split('-');
  return parts.length === 3 ? `${parts[2]}.${parts[1]}.${parts[0]}` : dateStr;
}

function bbUpdate() {
  const roomEl = document.getElementById('bb-room');
  const ciInput = document.getElementById('bb-checkin');
  const coInput = document.getElementById('bb-checkout');
  const sumBox = document.getElementById('bb-summary');
  
  if (!roomEl || !ciInput || !coInput || !sumBox) return;
  if (!ciInput.value || !coInput.value) {
      sumBox.innerHTML = '<div style="text-align:center;padding:10px;opacity:0.5;font-size:0.8rem;">Tarih seÃ§iniz...</div>';
      return;
  }

  const roomVal = roomEl.value;
  const ciDate = new Date(ciInput.value);
  const coDate = new Date(coInput.value);
  const adults = parseInt(document.getElementById('bb-adults').value) || 2;
  const children = parseInt(document.getElementById('bb-children').value) || 0;
  const totalPeople = adults + children;
  const breakfast = document.getElementById('bb-breakfast').checked;
  const transfer = document.getElementById('bb-transfer').checked;
  const lang = document.documentElement.lang || 'tr';

  const dayDiff = Math.ceil((coDate - ciDate) / (1000 * 3600 * 24));
  
  if (dayDiff > 0) {
    let baseRoomPrice = parseFloat(roomVal);
    const checkInMonth = ciDate.getMonth();
    const isSummer = checkInMonth >= 5 && checkInMonth <= 8;
    // Yaz sezonunda %30 indirim uygulanÄ±yor (isteÄŸe gÃ¶re revize edildi)
    if (isSummer) baseRoomPrice = baseRoomPrice * 0.70;

    const totalRoomPrice = baseRoomPrice * dayDiff;
    const breakfastPrice = breakfast ? 15 * dayDiff * totalPeople : 0;
    const transferPrice = transfer ? (totalPeople <= 5 ? 45 : 85) : 0;
    
    const totalEur = totalRoomPrice + breakfastPrice + transferPrice;
    const totalTry = totalEur * EXCHANGE_RATE;

    const allL = {
      tr: { room:'Oda', nights:'gece', breakfast:'KahvaltÄ±', transfer:'Transfer', total:'Toplam', person:'kiÅŸi', summer:'-30% yaz sezonu fiyatÄ± uygulanmÄ±ÅŸtÄ±r' },
      en: { room:'Room', nights:'nights', breakfast:'Breakfast', transfer:'Transfer', total:'Total', person:'pers', summer:'-30% summer season price applied' },
      de: { room:'Zimmer', nights:'NÃ¤chte', breakfast:'FrÃ¼hstÃ¼ck', transfer:'Transfer', total:'Gesamt', person:'Pers', summer:'-30% Sommerpreis angewendet' },
      ru: { room:'ĞĞ¾Ğ¼ĞµÑ€', nights:'Ğ½Ğ¾Ñ‡ĞµĞ¹', breakfast:'Ğ—Ğ°Ğ²Ñ‚Ñ€Ğ°Ğº', transfer:'Ğ¢Ñ€Ğ°Ğ½ÑÑ„ĞµÑ€', total:'Ğ˜Ñ‚Ğ¾Ğ³Ğ¾', person:'Ñ‡ĞµĞ»', summer:'ĞŸÑ€Ğ¸Ğ¼ĞµĞ½ĞµĞ½Ğ° ÑĞµĞ·Ğ¾Ğ½Ğ½Ğ°Ñ ÑĞºĞ¸Ğ´ĞºĞ° 30%' }
    };
    const L = allL[lang] || allL.tr;
    
    let html = `<div style="display:flex;justify-content:space-between;font-size:.82rem;padding:3px 0;color:rgba(255,255,255,.65)">
                  <span>${L.room} Ã— ${dayDiff} ${L.nights}</span>
                  <span style="color:#fff;font-weight:500;">${Math.round(totalRoomPrice)} â‚¬</span>
                </div>`;
    
    if (isSummer) html += `<div style="font-size:.7rem;color:#b8923a;padding:2px 0;">âœ¦ ${L.summer}</div>`;
    if (breakfast) html += `<div style="display:flex;justify-content:space-between;font-size:.82rem;padding:3px 0;color:rgba(255,255,255,.65)"><span>${L.breakfast} (${totalPeople} ${L.person})</span><span style="color:#fff;font-weight:500;">${Math.round(breakfastPrice)} â‚¬</span></div>`;
    if (transfer) html += `<div style="display:flex;justify-content:space-between;font-size:.82rem;padding:3px 0;color:rgba(255,255,255,.65)"><span>${L.transfer}</span><span style="color:#fff;font-weight:500;">${Math.round(transferPrice)} â‚¬</span></div>`;
    
    html += `<div style="height:1px;background:rgba(255,255,255,.1);margin:8px 0;"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:.82rem;font-weight:600;color:rgba(255,255,255,.9);text-transform:uppercase;letter-spacing:.06em;">${L.total}</span>
        <div style="text-align:right;">
          <span style="display:block;font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:600;color:#fff;line-height:1;">${Math.round(totalEur)} â‚¬</span>
          <span style="display:block;font-size:.85rem;font-weight:700;color:#f5dfa0;margin-top:4px;text-shadow:0 0 10px rgba(184,146,58,0.3);">â‰ˆ ${Math.round(totalTry).toLocaleString('tr-TR')} â‚º</span>
        </div>
      </div>`;

    sumBox.innerHTML = html;
  } else {
    sumBox.innerHTML = `<div style="text-align:center;padding:10px;color:#e74c3c;font-size:0.75rem;">Ã‡Ä±kÄ±ÅŸ tarihi giriÅŸten sonra olmalÄ±</div>`;
  }
}

function bbReserve() {
  const roomEl = document.getElementById('bb-room');
  const ci = document.getElementById('bb-checkin').value;
  const co = document.getElementById('bb-checkout').value;
  if (!ci || !co) { alert("LÃ¼tfen tarih seÃ§in."); return; }

  const roomText = roomEl.options[roomEl.selectedIndex].text;
  const ciDate = new Date(ci);
  const coDate = new Date(co);
  const dayDiff = Math.ceil((coDate - ciDate) / (1000 * 3600 * 24));
  
  if (dayDiff <= 0) { alert("Ã‡Ä±kÄ±ÅŸ tarihi giriÅŸten sonra olmalÄ±."); return; }

  const adults = parseInt(document.getElementById('bb-adults').value) || 2;
  const children = parseInt(document.getElementById('bb-children').value) || 0;
  const totalPeople = adults + children;
  const breakfast = document.getElementById('bb-breakfast').checked;
  const transfer = document.getElementById('bb-transfer').checked;
  const lang = document.documentElement.lang || 'tr';

  let baseRoomPrice = parseFloat(roomEl.value);
  if (ciDate.getMonth() >= 5 && ciDate.getMonth() <= 8) baseRoomPrice = baseRoomPrice * 0.70;

  const totalRoomPrice = baseRoomPrice * dayDiff;
  const breakfastPrice = breakfast ? 15 * dayDiff * totalPeople : 0;
  const transferPrice = transfer ? (totalPeople <= 5 ? 45 : 85) : 0;
  const totalEur = totalRoomPrice + breakfastPrice + transferPrice;
  const totalTry = totalEur * EXCHANGE_RATE;

  const headers = { tr:'Merhaba, yeni bir rezervasyon talebi var:', en:'Hello, there is a new reservation request:', de:'Hallo, es gibt eine neue Reservierungsanfrage:', ru:'Ğ—Ğ´Ñ€Ğ°Ğ²ÑÑ‚Ğ²ÑƒĞ¹Ñ‚Ğµ, Ğ¿Ğ¾ÑÑ‚ÑƒĞ¿Ğ¸Ğ» Ğ½Ğ¾Ğ²Ñ‹Ğ¹ Ğ·Ğ°Ğ¿Ñ€Ğ¾Ñ Ğ½Ğ° Ğ±Ñ€Ğ¾Ğ½Ğ¸Ñ€Ğ¾Ğ²Ğ°Ğ½Ğ¸Ğµ:' };
  const labels = {
    tr: { r:'Oda Tipi', i:'GiriÅŸ', o:'Ã‡Ä±kÄ±ÅŸ', n:'Konaklama', g:'Misafirler', b:'KahvaltÄ±', t:'Transfer', tot:'Toplam Tutar' },
    en: { r:'Room Type', i:'Check-in', o:'Check-out', n:'Stay', g:'Guests', b:'Breakfast', t:'Transfer', tot:'Total Amount' },
    de: { r:'Zimmertyp', i:'Anreise', o:'Abreise', n:'Aufenthalt', g:'GÃ¤ste', b:'FrÃ¼hstÃ¼ck', t:'Transfer', tot:'Gesamtbetrag' },
    ru: { r:'Ğ¢Ğ¸Ğ¿ Ğ½Ğ¾Ğ¼ĞµÑ€Ğ°', i:'Ğ—Ğ°ĞµĞ·Ğ´', o:'Ğ’Ñ‹ĞµĞ·Ğ´', n:'ĞŸÑ€Ğ¾Ğ¶Ğ¸Ğ²Ğ°Ğ½Ğ¸Ğµ', g:'Ğ“Ğ¾ÑÑ‚Ğ¸', b:'Ğ—Ğ°Ğ²Ñ‚Ñ€Ğ°Ğº', t:'Ğ¢Ñ€Ğ°Ğ½ÑÑ„ĞµÑ€', tot:'Ğ˜Ñ‚Ğ¾Ğ³Ğ¾Ğ²Ğ°Ñ ÑÑƒĞ¼Ğ¼Ğ°' }
  };
  const L = labels[lang] || labels.tr;

  let msg = `${headers[lang] || headers.tr}\n\n`;
  msg += `ğŸ  ${L.r}: ${roomText}\n`;
  msg += `ğŸ“… ${L.i}: ${formatDate(ci)}\n`;
  msg += `ğŸ“… ${L.o}: ${formatDate(co)}\n`;
  msg += `ğŸŒ™ ${L.n}: ${dayDiff} Gece\n`;
  msg += `ğŸ‘¤ ${L.g}: ${adults} YetiÅŸkin, ${children} Ã‡ocuk\n`;
  msg += `â˜• ${L.b}: ${breakfast ? 'Evet (' + Math.round(breakfastPrice) + 'â‚¬)' : 'HayÄ±r'}\n`;
  msg += `ğŸš˜ ${L.t}: ${transfer ? 'Evet (' + Math.round(transferPrice) + 'â‚¬)' : 'HayÄ±r'}\n\n`;
  msg += `ğŸ’° ${L.tot}: ${Math.round(totalEur)} â‚¬ (~${Math.round(totalTry).toLocaleString('tr-TR')} â‚º)`;

  window.open(`https://wa.me/${WA_NUM}?text=${encodeURIComponent(msg)}`, '_blank');
}

function initBooking() {
  const ciInput = document.getElementById('bb-checkin');
  const coInput = document.getElementById('bb-checkout');
  if (!ciInput || !coInput) return;
  
  const today = new Date().toISOString().split('T')[0];
  ciInput.min = today;
  if (!ciInput.value) ciInput.value = today;

  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  const tomorrowStr = tomorrow.toISOString().split('T')[0];
  coInput.min = tomorrowStr;
  if (!coInput.value) coInput.value = tomorrowStr;

  ciInput.addEventListener('change', () => {
    const nextDay = new Date(ciInput.value);
    nextDay.setDate(nextDay.getDate() + 1);
    const nextDayStr = nextDay.toISOString().split('T')[0];
    coInput.min = nextDayStr;
    if (coInput.value <= ciInput.value) coInput.value = nextDayStr;
    bbUpdate();
  });

  ['bb-room','bb-checkin','bb-checkout','bb-adults','bb-children','bb-breakfast','bb-transfer'].forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.addEventListener('change', bbUpdate);
      el.addEventListener('input', bbUpdate);
    }
  });

  const btn = document.getElementById('bb-reserve-btn');
  if (btn) btn.addEventListener('click', bbReserve);

  const havalePayEl = document.getElementById('bb-pay-havale');
  if (havalePayEl && !havalePayEl.dataset.boundPayRedirect) {
    havalePayEl.dataset.boundPayRedirect = '1';
    havalePayEl.addEventListener('change', () => {
      if (havalePayEl.checked) {
        window.open(`https://wa.me/${WA_NUM}?text=${encodeURIComponent('Hesap numaranÄ±zÄ± verir misiniz?')}`, '_blank');
      }
    });
  }

  const cardPayEl = document.getElementById('bb-pay-kart');
  if (cardPayEl && !cardPayEl.dataset.boundPayRedirect) {
    cardPayEl.dataset.boundPayRedirect = '1';
    cardPayEl.addEventListener('change', () => {
      if (cardPayEl.checked) window.open('https://payment.belkagolf.com', '_blank');
    });
  }

  bbUpdate();
}

