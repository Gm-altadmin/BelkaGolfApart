  <style>
    /* â•â• RESET & BASE â•â• */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body { font-family: 'Jost', sans-serif; background: #f8f5f0; color: #1a1a1a; overflow-x: hidden; }
    h1,h2,h3,h4,p,span,a,label,div { overflow-wrap: break-word; word-wrap: break-word; }
    img { display: block; width: 100%; height: 100%; object-fit: cover; }
    a { text-decoration: none; color: inherit; }

    /* â•â• NAV â•â• */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 999;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 48px; height: 72px; transition: all 0.5s ease;
    }
    nav.scrolled {
      background: rgba(248,245,240,0.97);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 0 rgba(0,0,0,0.06);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem; font-weight: 500; letter-spacing: 0.06em;
      color: #fff; transition: color 0.4s; line-height: 1;
    }
    .nav-logo span {
      display: block; font-family: 'Jost', sans-serif;
      font-size: 0.55rem; font-weight: 400; letter-spacing: 0.25em;
      text-transform: uppercase; color: rgba(255,255,255,0.55);
      margin-top: 3px; transition: color 0.4s;
    }
    nav.scrolled .nav-logo { color: #1a1a1a; }
    nav.scrolled .nav-logo span { color: #b8923a; }
    .nav-links { display: flex; align-items: center; gap: 28px; }
    .nav-links a {
      font-size: 0.68rem; font-weight: 400; letter-spacing: 0.16em;
      text-transform: uppercase; color: rgba(255,255,255,0.8);
      transition: color 0.3s; position: relative; white-space: nowrap;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -3px; left: 0; right: 100%;
      height: 1px; background: #b8923a; transition: right 0.3s ease;
    }
    .nav-links a:hover { color: #fff; }
    .nav-links a:hover::after { right: 0; }
    nav.scrolled .nav-links a { color: #4a4a4a; }
    nav.scrolled .nav-links a:hover { color: #1a1a1a; }
    .nav-reserve {
      font-size: 0.68rem !important; font-weight: 500 !important;
      letter-spacing: 0.18em !important; color: #fff !important;
      border: 1px solid rgba(255,255,255,0.5);
      padding: 9px 20px; border-radius: 2px;
      transition: all 0.3s !important; white-space: nowrap;
    }
    .nav-reserve::after { display: none !important; }
    .nav-reserve:hover { background: rgba(255,255,255,0.12) !important; border-color: rgba(255,255,255,0.9) !important; }
    nav.scrolled .nav-reserve { color: #1a1a1a !important; border-color: rgba(0,0,0,0.25) !important; }
    nav.scrolled .nav-reserve:hover { background: #1a1a1a !important; color: #fff !important; border-color: #1a1a1a !important; }
    .lang-switcher {
      display: flex; align-items: center; gap: 0;
      margin-left: 24px; border-left: 1px solid rgba(255,255,255,0.18);
      padding-left: 18px;
    }
    nav.scrolled .lang-switcher { border-left-color: rgba(0,0,0,0.1); }
    .lang-btn {
      background: none; border: 1px solid rgba(255,255,255,0.2); cursor: pointer;
      font-family: 'Jost', sans-serif; font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: #fff; padding: 6px 10px; transition: all 0.3s;
      border-radius: 2px; margin: 0 2px;
    }
    .lang-btn:hover { background: rgba(255,255,255,0.1); border-color: #fff; }
    .lang-btn.active { color: #fff; background: #b8923a; border-color: #b8923a; }
    nav.scrolled .lang-btn { color: #1a1a1a; border-color: rgba(0,0,0,0.15); }
    nav.scrolled .lang-btn:hover { background: rgba(0,0,0,0.05); border-color: #1a1a1a; }
    nav.scrolled .lang-btn.active { color: #fff; background: #b8923a; border-color: #b8923a; }

    /* Mobil Dil SeÃ§ici */
    .mobile-lang {
      display: flex; gap: 10px;
      padding-bottom: 28px; margin-bottom: 4px; border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .mobile-lang .lang-btn {
      flex: 1; text-align: center; padding: 12px 0;
      font-size: 0.85rem; border-color: rgba(255,255,255,0.2);
    }
    .lang-sep { color: rgba(255,255,255,0.2); font-size: 0.6rem; pointer-events: none; }
    nav.scrolled .lang-sep { color: rgba(0,0,0,0.15); }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .hamburger span { width: 22px; height: 1.5px; background: white; transition: background 0.3s; }
    nav.scrolled .hamburger span { background: #1a1a1a; }
    .mobile-nav {
      position: fixed; top: 0; right: -100%; width: 280px; height: 100vh;
      background: #0f1a10; z-index: 1000; padding: 80px 40px 40px;
      display: flex; flex-direction: column; gap: 24px;
      transition: right 0.4s ease;
      overflow-y: auto;
    }
    .mobile-nav.open { right: 0; }
    .mobile-nav a {
      font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(255,255,255,0.7); transition: color 0.2s;
    }
    .mobile-nav a:hover { color: #b8923a; }
    .mobile-close {
      position: absolute; top: 24px; right: 24px;
      color: rgba(255,255,255,0.5); font-size: 1.2rem; cursor: pointer;
      background: none; border: none;
    }

    /* â•â• HERO â•â• */
    #hero {
      height: 100vh; min-height: 640px; position: relative;
      display: flex; flex-direction: column; align-items: center; justify-content: flex-end; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background: url('images/havuzhero.webp') center center / cover no-repeat;
      transform: scale(1.04);
      animation: heroZoom 12s ease-out forwards;
    }
    @keyframes heroZoom { from { transform: scale(1.04); } to { transform: scale(1); } }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(8,18,10,0.88) 0%, rgba(8,18,10,0.50) 50%, rgba(8,18,10,0.38) 100%);
    }
    .hero-content {
      position: relative; z-index: 2;
      padding: 0 80px 100px; max-width: 900px; width: 100%;
      text-align: center;
      margin: 0 auto;
    }
    .hero-label {
      font-size: 0.7rem; font-weight: 500; letter-spacing: 0.3em;
      text-transform: uppercase; color: rgba(255,255,255,0.92);
      margin-bottom: 20px; text-shadow: 0 2px 16px rgba(0,0,0,0.5);
      opacity: 0; animation: fadeUp 1s ease 0.3s forwards;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 4.8vw, 4.6rem);
      font-weight: 400; line-height: 1.15; color: #fff;
      margin-bottom: 24px;
      text-shadow: 0 4px 30px rgba(0,0,0,0.55), 0 1px 3px rgba(0,0,0,0.4);
      opacity: 0; animation: fadeUp 1s ease 0.5s forwards;
    }
    .hero-title em { font-style: italic; font-weight: 400; color: #f5dfa0; }
    .hero-desc {
      font-size: 0.95rem; font-weight: 400; color: rgba(255,255,255,0.92);
      line-height: 1.75; letter-spacing: 0.02em; max-width: 520px;
      margin: 0 auto 36px auto; text-shadow: 0 2px 14px rgba(0,0,0,0.6);
      opacity: 0; animation: fadeUp 1s ease 0.7s forwards;
    }
    .hero-actions {
      display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;
      opacity: 0; animation: fadeUp 1s ease 0.9s forwards;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: #b8923a; color: #fff; padding: 14px 28px; border-radius: 2px;
      font-size: 0.7rem; font-weight: 500; letter-spacing: 0.18em;
      text-transform: uppercase; transition: all 0.3s; white-space: nowrap;
    }
    .btn-primary:hover { background: #a07c2e; transform: translateY(-2px); }
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 10px;
      border: 1px solid rgba(255,255,255,0.4); color: #fff;
      padding: 14px 28px; border-radius: 2px;
      font-size: 0.7rem; font-weight: 400; letter-spacing: 0.18em;
      text-transform: uppercase; transition: all 0.3s; white-space: nowrap;
    }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.08); }
    .hero-rating {
      position: relative; z-index: 2;
      text-align: center; opacity: 0; animation: fadeUp 1s ease 1.1s forwards;
      margin-top: 40px;
      padding-bottom: 100px;
    }
    .rating-score {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3.2rem; font-weight: 300; color: #fff; line-height: 1;
    }
    .rating-stars { color: #b8923a; font-size: 0.7rem; letter-spacing: 4px; margin: 4px 0; }
    .rating-text { font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.5); }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    /* â•â• REZERVASYON BARI â•â• */
    #booking-bar { background: #1a2a1c; padding: 40px 80px; }
    .bb-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem; font-weight: 400; color: #fff;
      margin-bottom: 6px; letter-spacing: 0.02em;
    }
    .bb-subtitle { font-size: 0.7rem; color: rgba(255,255,255,0.45); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 28px; }
    .bb-form {
      display: grid;
      grid-template-columns: minmax(0,2fr) repeat(4, minmax(0,1fr));
      gap: 16px; align-items: end;
      width: 100%;
    }
    .bb-field { display: flex; flex-direction: column; gap: 8px; }
    .bb-label {
      font-size: 0.58rem; font-weight: 600; letter-spacing: 0.22em;
      text-transform: uppercase; color: rgba(255,255,255,0.45);
    }
    .bb-select, .bb-input {
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
      color: #fff; padding: 12px 14px; font-family: 'Jost', sans-serif;
      font-size: 0.85rem; border-radius: 2px; outline: none;
      transition: border-color 0.2s; width: 100%;
      -webkit-appearance: none; appearance: none;
    }
    .bb-select option { background: #1a2a1c; color: #fff; }
    .bb-select:focus, .bb-input:focus { border-color: #b8923a; }
    .bb-input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1) opacity(0.5); cursor: pointer; }
    .bb-extras-row { margin-top: 20px; }
    .bb-extras-label { font-size: 0.58rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 12px; }
    .bb-extras { display: flex; gap: 28px; flex-wrap: wrap; }
    .bb-check { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .bb-check input[type="checkbox"] { position: absolute; opacity: 0; pointer-events: none; }
    .bb-check-box {
      width: 16px; height: 16px; border: 1px solid rgba(255,255,255,0.25);
      border-radius: 2px; position: relative; transition: all 0.2s;
    }
    .bb-check input:checked + .bb-check-box { background: #b8923a; border-color: #b8923a; }
    .bb-check input:checked + .bb-check-box::after {
      content: 'âœ“'; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      color: #fff; font-size: 0.6rem;
    }
    .bb-check-label { font-size: 0.85rem; color: rgba(255,255,255,0.85); }
    .bb-check-label em { font-style: normal; font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-left: 8px; }
    
    .bb-bottom {
      margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1);
      display: flex; justify-content: space-between; align-items: flex-end; gap: 40px;
    }
    .bb-summary-box { flex: 1; max-width: 500px; }
    .bb-summary-title { font-size: 0.58rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 16px; }
    #bb-summary { min-height: 80px; }
    .bb-actions { display: flex; flex-direction: column; gap: 16px; min-width: 240px; }
    .bb-pay-row { display: flex; gap: 12px; }
    .bb-pay-opt {
      flex: 1; position: relative; cursor: pointer;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      padding: 10px; border-radius: 2px; text-align: center;
      font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.5);
      transition: all 0.2s;
    }
    .bb-pay-opt input { position: absolute; opacity: 0; pointer-events: none; }
    .bb-pay-opt:has(input:checked) { background: rgba(184,146,58,0.1); border-color: #b8923a; color: #fff; }
    .bb-btn {
      background: #b8923a; color: #fff; border: none; padding: 16px; border-radius: 2px;
      font-size: 0.75rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
      cursor: pointer; transition: all 0.3s;
    }
    .bb-btn:hover { background: #a07c2e; transform: translateY(-2px); }
    .bb-rate-info { margin-top: 12px; font-size: 0.65rem; color: rgba(255,255,255,0.3); letter-spacing: 0.05em; }

    /* â•â• INTRO â•â• */
    #intro { padding: 120px 80px; background: #fff; }
    .intro-grid { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 80px; align-items: center; }
    .section-eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.35em; text-transform: uppercase; color: #b8923a; margin-bottom: 16px; }
    .gold-line { width: 40px; height: 1px; background: #b8923a; }
    .section-title { font-family: 'Cormorant Garamond', serif; font-size: 2.8rem; font-weight: 400; color: #1a1a1a; line-height: 1.2; margin-bottom: 24px; }
    .intro-desc { font-size: 1.05rem; line-height: 1.8; color: #4a4a4a; margin-bottom: 40px; }
    .intro-features { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 32px; }
    .intro-feat-item h4 { font-size: 0.85rem; font-weight: 600; letter-spacing: 0.05em; color: #1a1a1a; margin-bottom: 8px; }
    .intro-feat-item p { font-size: 0.85rem; line-height: 1.6; color: #777; }
    .intro-image { position: relative; padding-bottom: 125%; overflow: hidden; }
    .intro-image img { position: absolute; inset: 0; transition: transform 0.8s ease; }
    .intro-image:hover img { transform: scale(1.05); }

    /* â•â• KONUM â•â• */
    #konum-section { padding: 100px 80px; background: #faf8f4; }
    .loc-grid { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1.5fr); gap: 60px; }
    .loc-list { display: flex; flex-direction: column; gap: 24px; }
    .loc-item { display: flex; gap: 20px; align-items: flex-start; }
    .loc-icon { font-size: 1.2rem; color: #b8923a; margin-top: 3px; }
    .loc-text h4 { font-size: 0.9rem; font-weight: 600; color: #1a1a1a; margin-bottom: 4px; }
    .loc-text p { font-size: 0.85rem; color: #777; }
    .map-container { height: 450px; background: #eee; border-radius: 2px; overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.05); }

    /* â•â• DAÄ°RELER â•â• */
    #daireler { padding: 120px 80px; background: #fff; }
    .rooms-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 32px; margin-top: 60px; }
    .room-card { background: #fff; border: 1px solid #f0ece5; transition: all 0.4s; }
    .room-card:hover { transform: translateY(-10px); box-shadow: 0 30px 60px rgba(0,0,0,0.07); border-color: transparent; }
    .room-img { height: 280px; overflow: hidden; }
    .room-img img { transition: transform 0.6s; }
    .room-card:hover .room-img img { transform: scale(1.1); }
    .room-info { padding: 32px; }
    .room-type { font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: #b8923a; margin-bottom: 12px; }
    .room-name { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 400; color: #1a1a1a; margin-bottom: 16px; }
    .room-desc { font-size: 0.85rem; line-height: 1.7; color: #666; margin-bottom: 24px; height: 70px; overflow: hidden; }
    .room-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 24px; border-top: 1px solid #f0ece5; }
    .room-price { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: #1a1a1a; }
    .room-price sub { font-family: 'Jost', sans-serif; font-size: 0.6rem; letter-spacing: 0.1em; bottom: 0; color: #aaa; }
    .room-link { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #b8923a; }

    /* â•â• POOL SECTION â•â• */
    #pool-section { height: 80vh; min-height: 500px; position: relative; display: flex; align-items: center; justify-content: center; text-align: center; color: #fff; overflow: hidden; }
    .pool-bg { position: absolute; inset: 0; background: url('images/havuzhero.webp') center center / cover no-repeat; z-index: 1; transition: transform 0.5s; }
    #pool-section:hover .pool-bg { transform: scale(1.05); }
    .pool-overlay { position: absolute; inset: 0; background: rgba(8,18,10,0.5); z-index: 2; }
    .pool-content { position: relative; z-index: 3; max-width: 700px; padding: 0 40px; }

    /* â•â• Ã–ZELLÄ°KLER â•â• */
    #ozellikler { padding: 120px 80px; background: #faf8f4; }
    .feats-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 40px; margin-top: 60px; }
    .feat-box { text-align: center; }
    .feat-icon { font-size: 1.8rem; color: #b8923a; margin-bottom: 20px; }
    .feat-box h4 { font-size: 0.9rem; font-weight: 600; color: #1a1a1a; margin-bottom: 10px; }
    .feat-box p { font-size: 0.8rem; line-height: 1.6; color: #777; }

    /* â•â• GALERÄ° / KAROSEL â•â• */
    #galeri { padding: 120px 80px; background: #fff; }
    .gc-wrap { margin-top: 60px; }
    .gc-stage {
      position: relative; width: 100%; aspect-ratio: 16/8.5; max-height: 620px;
      overflow: hidden; background: #0f1a10; border-radius: 2px;
    }
    .gc-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.8s ease; }
    .gc-slide.active { opacity: 1; z-index: 1; }
    .gc-slide img { width: 100%; height: 100%; object-fit: cover; }
    .gc-slide::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(0deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 35%);
      z-index: 1;
    }
    .gc-caption {
      position: absolute; bottom: 26px; left: 32px; z-index: 2; color: #fff;
      font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-style: italic;
      text-shadow: 0 2px 12px rgba(0,0,0,0.5);
    }
    .gc-counter {
      position: absolute; bottom: 30px; right: 32px; z-index: 2; color: #fff;
      font-family: 'Jost', sans-serif; font-size: 0.68rem; letter-spacing: 0.16em;
      background: rgba(0,0,0,0.35); padding: 7px 16px; border-radius: 20px;
      backdrop-filter: blur(6px); border: 1px solid rgba(255,255,255,0.2);
    }
    .gc-arrow {
      position: absolute; top: 50%; transform: translateY(-50%); z-index: 3;
      width: 50px; height: 50px; border-radius: 50%; cursor: pointer;
      background: rgba(255,255,255,0.12); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.4); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; transition: all 0.3s;
    }
    .gc-arrow:hover { background: #b8923a; border-color: #b8923a; }
    .gc-prev { left: 24px; }
    .gc-next { right: 24px; }

    /* â•â• VIKING19 â•â• */
    #viking {
      display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr);
      min-height: 70vh;
    }
    .viking-img {
      position: relative; overflow: hidden;
      background: url('images/park1.webp') center / cover no-repeat;
    }
    .viking-text {
      background: #1a2a1c;
      display: flex; flex-direction: column; justify-content: center;
      padding: 100px 80px;
    }
    .viking-text .section-eyebrow { color: rgba(255,255,255,0.4); }
    .viking-text .section-title { color: #fff; }
    .viking-text .section-body { color: rgba(255,255,255,0.55); max-width: 100%; font-size: 1rem; font-weight: 300; line-height: 1.9; margin-bottom: 40px; }
    .viking-text .gold-line { background: #b8923a; }

    /* â•â• PLATFORM PUANLARI BANDI â•â• */
    .platform-bar {
      background: #fff;
      display: flex; align-items: stretch; flex-wrap: wrap;
      border-bottom: 1px solid #f0ece5;
      border-top: 1px solid #f0ece5;
    }
    .platform-item {
      flex: 1 1 160px; min-width: 0; padding: 22px 28px;
      text-align: center; border-right: 1px solid #f0ece5;
      transition: background 0.2s;
    }
    .platform-item:last-child { border-right: none; }
    .platform-item:hover { background: #faf8f4; }
    .platform-name { font-size: 0.58rem; letter-spacing: 0.25em; text-transform: uppercase; color: #b8923a; margin-bottom: 8px; }
    .platform-score { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; color: #1a1a1a; line-height: 1; }
    .platform-stars { font-size: 0.6rem; color: #b8923a; letter-spacing: 3px; margin: 5px 0; }
    .platform-count { font-size: 0.6rem; color: #aaa; letter-spacing: 0.1em; }
    .platform-link {
      display: inline-block; margin-top: 10px; font-size: 0.58rem;
      letter-spacing: 0.18em; text-transform: uppercase; color: #b8923a;
      border-bottom: 1px solid rgba(184,146,58,0.3); padding-bottom: 1px;
      transition: border-color 0.2s;
    }
    .platform-link:hover { border-color: #b8923a; }

    /* â•â• YORUMLAR â•â• */
    #yorumlar { padding: 120px 80px; background: #fff; }
    .rev-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 32px; margin-top: 60px; }
    .rev-card { padding: 40px; border: 1px solid #f0ece5; text-align: center; }
    .rev-stars { color: #b8923a; font-size: 0.7rem; letter-spacing: 3px; margin-bottom: 20px; }
    .rev-text { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-style: italic; color: #1a1a1a; line-height: 1.5; margin-bottom: 24px; }
    .rev-author { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #aaa; }

    /* â•â• FOOTER â•â• */
    footer { background: #08120a; color: #fff; padding: 100px 80px 40px; }
    .footer-grid { display: grid; grid-template-columns: minmax(0,1.5fr) minmax(0,1fr) minmax(0,1fr) minmax(0,1.2fr); gap: 60px; margin-bottom: 80px; }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: #fff; margin-bottom: 20px; }
    .footer-desc { font-size: 0.85rem; color: rgba(255,255,255,0.4); line-height: 1.8; margin-bottom: 30px; }
    .footer-social { display: flex; gap: 16px; }
    .footer-social a { width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; transition: all 0.3s; }
    .footer-social a:hover { border-color: #b8923a; color: #b8923a; }
    .footer-col h4 { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #fff; margin-bottom: 24px; }
    .footer-links { display: flex; flex-direction: column; gap: 14px; }
    .footer-links a { font-size: 0.85rem; color: rgba(255,255,255,0.5); transition: color 0.2s; }
    .footer-links a:hover { color: #b8923a; }
    .footer-contact-item { display: flex; gap: 16px; margin-bottom: 20px; }
    .footer-contact-item i { color: #b8923a; font-size: 1rem; }
    .footer-contact-text p { font-size: 0.85rem; color: rgba(255,255,255,0.5); line-height: 1.5; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.08); padding-top: 40px; display: flex; justify-content: space-between; align-items: center; }
    .footer-copy { font-size: 0.75rem; color: rgba(255,255,255,0.3); }

    /* â•â• WHATSAPP FAB â•â• */
    .wa-fab { position: fixed; bottom: 30px; right: 30px; width: 60px; height: 60px; background: #25d366; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.8rem; z-index: 998; box-shadow: 0 10px 25px rgba(37,211,102,0.3); transition: transform 0.3s; }
    .wa-fab:hover { transform: scale(1.1); }

    /* â•â• REVEAL ANIMATION â•â• */
    .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* â•â• RESPONSIVE â•â• */
    @media (max-width: 1200px) {
      nav { padding: 0 32px; }
      .hero-content { padding: 0 40px 80px; }
      #booking-bar { padding: 40px; }
      .bb-form { grid-template-columns: repeat(3, minmax(0,1fr)); }
      #intro, #daireler, #ozellikler, #galeri, #viking, #yorumlar, #konum-section, footer { padding-left: 40px; padding-right: 40px; }
      .feats-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
    }
    @media (max-width: 992px) {
      .intro-grid, .loc-grid { grid-template-columns: minmax(0,1fr); gap: 40px; }
      #viking { grid-template-columns: minmax(0,1fr); }
      .viking-img { height: 50vh; }
      .viking-text { padding: 60px 40px; }
      .rooms-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .rev-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .footer-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
    }
    @media (max-width: 768px) {
      .nav-links, .lang-switcher { display: none; }
      .hamburger { display: flex; }
      #booking-bar { padding: 32px 24px; }
      .bb-form { grid-template-columns: minmax(0,1fr); }
      .bb-bottom { flex-direction: column; align-items: stretch; }
      .bb-summary-box { max-width: 100%; }
      .bb-actions { min-width: 100%; }
      .bb-extras { gap: 16px 24px; }
      #intro, #daireler, #ozellikler, #galeri, #viking, #yorumlar, #konum-section, footer { padding-left: 24px; padding-right: 24px; }
      .viking-text { padding: 60px 24px; }
      .hero-content { padding: 0 24px 80px; }
      nav { padding: 0 20px; }
      .intro-features { grid-template-columns: minmax(0,1fr); }
      .rooms-grid { grid-template-columns: minmax(0,1fr); }
      .rev-grid { grid-template-columns: minmax(0,1fr); }
      .platform-item { flex: 1 1 50%; border-right: none; border-bottom: 1px solid #f0ece5; }
      .platform-item:nth-child(2n) { border-right: none; }
      .gc-stage { aspect-ratio: 4/3.4; max-height: none; }
      .gc-arrow { width: 40px; height: 40px; font-size: 0.85rem; }
      .gc-caption { font-size: 1.15rem; left: 20px; bottom: 18px; }
      .gc-counter { right: 20px; bottom: 22px; }
      .footer-grid { grid-template-columns: minmax(0,1fr); }
      .footer-bottom { flex-direction: column; gap: 20px; text-align: center; }
    }
    @media (max-width: 480px) {
      #booking-bar { padding: 24px 16px; }
      .bb-title { font-size: 1.3rem; }
      .bb-form { gap: 12px; }
      .bb-pay-row { flex-direction: column; gap: 10px; }
      .bb-extras { flex-direction: column; gap: 14px; }
      #intro, #daireler, #ozellikler, #galeri, #viking, #yorumlar, #konum-section, footer { padding-left: 16px; padding-right: 16px; }
      .viking-text { padding: 50px 16px; }
      .hero-content { padding: 0 16px 60px; }
      nav { padding: 0 16px; }
      .section-title { font-size: 2.1rem; }
      .rev-card { padding: 28px 20px; }
      .platform-item { flex: 1 1 100%; }
    }
  </style>
</head>
